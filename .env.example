# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Push notifications via ntfy.sh ────────────────────────────────────────────
# 1. Pick a unique topic name (treat it like a password — it's public by default)
# 2. Subscribe at https://ntfy.sh/<your-topic> in any browser, or install the
#    ntfy app (iOS / Android) and subscribe to the same topic.
# 3. Set the variable below and notifications arrive automatically after each digest.
NTFY_TOPIC=my-digest-abc123

# ── Web app URL (used in notification body) ───────────────────────────────────
# If you serve locally:  http://localhost:8000
# If deployed somewhere: https://digest.yoursite.com
DIGEST_APP_URL=http://localhost:8000

# ── Obsidian integration (optional) ──────────────────────────────────────────
# Absolute path to your Obsidian vault root.
# The script creates a "Дайджести" folder inside and saves
# "Comms Strategy Digest YYYY-MM-DD.md" there automatically.
# OBSIDIAN_VAULT_PATH=/home/yourname/Documents/MyVault

# ── Misc ──────────────────────────────────────────────────────────────────────
DIGEST_TIMEZONE=EET
